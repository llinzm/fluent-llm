        "well_offset": "list(range(8))"
      }
    },
    {
      "type": "dispense_volume",
      "params": {
        "volumes": 50,
        "labware": "dilution_plate",
        "liquid_class": "Water_Free_Single",
        "well_offset": "list(range(8))"
      }
    },
    {
      "type": "drop_tips_to_location",
      "params": {
        "labware": "DiTi_waste"
      }
    },
    {
      "type": "get_tips",
      "params": {
        "diti_type": "FCA_DiTi_200uL"
      }
    },
    {
      "type": "aspirate_volume",
      "params": {
        "volumes": 50,
        "labware": "tube_runner",
        "liquid_class": "Water_Free_Single",
        "well_offset": "list(range(8,16))"
      }
    },
    {
      "type": "dispense_volume",
      "params": {
        "volumes": 50,
        "labware": "dilution_plate",
        "liquid_class": "Water_Free_Single",
        "well_offset": "list(range(8,16))"
